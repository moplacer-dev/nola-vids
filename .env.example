# Veo API Configuration
GOOGLE_GENAI_API_KEY=your_google_api_key_here

# Server Configuration
PORT=5173

# Access Key (required to use the app)
ACCESS_KEY=your_access_key_here

# CORS Configuration (optional, defaults to allow all origins)
# Comma-separated list of allowed origins, or '*' for all
# CORS_ORIGINS=https://your-app.onrender.com

# Supabase Configuration (required)
# Get these from your Supabase project settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ElevenLabs TTS Configuration
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_DEFAULT_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Directus CMS Configuration (for Sync with CMS feature)
DIRECTUS_API_URL=https://www.nola.tools
DIRECTUS_API_TOKEN=your_directus_api_token_here
DIRECTUS_CARL_COURSE_ID=your_carl_course_id_here
